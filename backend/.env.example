PORT=5001
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret

# Local MySQL connection.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_citizen_portal

# Sequelize database settings.
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_citizen_portal
DB_SYNC=true
DB_SEED=true
DB_SEED_COMPLAINTS=false

# Railway MySQL plugin variables are also supported automatically:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQL_URL

# Optional AI integration.
GEMINI_API_KEY=

# Public URL used in reset links and email templates.
PUBLIC_APP_URL=http://localhost:5173

# Upload hardening.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100

# Optional real email notifications (SMTP). Leave blank for demo mode.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional real SMS notifications (Twilio). Leave blank for demo mode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
NOTIFICATION_DEBUG=false
