PORT=5001
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret

# Local MySQL connection.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=smart_citizen_portal

# Sequelize database settings.
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_citizen_portal
DB_SYNC=true
DB_SEED=true

# Railway MySQL plugin variables are also supported automatically:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQL_URL

# Optional AI integration.
GEMINI_API_KEY=
